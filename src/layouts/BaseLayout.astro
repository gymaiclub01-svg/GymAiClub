---
import '../styles/global.css';
import { t, languages, localePath, type Lang } from '../i18n/utils';

interface Props {
  lang: Lang;
  title?: string;
  description?: string;
}
const { lang, title: pageTitle, description: pageDescription } = Astro.props;

const title = pageTitle ?? t(lang, 'meta.title');
const description = pageDescription ?? t(lang, 'meta.description');
const locales = Object.keys(languages) as Lang[];
---
<!doctype html>
<html lang={lang}>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" href="/favicon.ico" sizes="any" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <title>{title}</title>
  <meta name="description" content={description} />

  {locales.map((l) => (
    <link rel="alternate" hreflang={l} href={localePath(l)} />
  ))}
  <link rel="alternate" hreflang="x-default" href={localePath('en')} />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
</head>
<body>
  <slot />
</body>
</html>
