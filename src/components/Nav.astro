---
import Logo from './Logo.astro';
import LanguageSwitcher from './LanguageSwitcher.astro';
import { t, localePath, type Lang } from '../i18n/utils';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const home = localePath(lang);
---
<nav>
  <div class="wrap inner">
    <a href={home} style="display:flex; align-items:center; gap:11px;">
      <Logo />
      <span class="brand">gym<span class="ai">ai</span>club</span>
    </a>
    <div class="nav-right">
      <div class="navlinks">
        <a href={`${home}#features`}>{t(lang, 'nav.features')}</a>
        <a href={`${home}#showcase`}>{t(lang, 'nav.app')}</a>
        <a href={`${home}#how`}>{t(lang, 'nav.how')}</a>
        <a href={`${home}#faq`}>{t(lang, 'nav.faq')}</a>
        <a href={`${home}#contact`}>{t(lang, 'nav.contact')}</a>
      </div>
      <LanguageSwitcher lang={lang} />
    </div>
  </div>
</nav>
