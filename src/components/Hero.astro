---
import { Image } from 'astro:assets';
import { t, type Lang } from '../i18n/utils';
import homeShot from '../assets/screenshots/home.png';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
---
<header class="hero wrap">
  <div class="hero-glow"></div>
  <div style="position:relative; z-index:2;">
    <div class="kicker"><span class="dot"></span><span>{t(lang, 'hero.badge')}</span></div>
    <h1>{t(lang, 'hero.title_1')}<br>{t(lang, 'hero.title_2')} <span class="g">{t(lang, 'hero.title_accent')}</span></h1>
    <p class="lead">{t(lang, 'hero.lead')}</p>
    <div class="store-row">
      <a href="#download" class="store-btn btn-hover" style="background:#fff; color:#06140C;">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="#06140C"><path d="M16 1c-1 0-2.5.7-3.4 1.7-.8.9-1.4 2.2-1.2 3.4 1.1.1 2.5-.6 3.3-1.6.8-.9 1.4-2.2 1.3-3.5zM20.5 17c-.5 1.2-1.1 2.3-1.9 3.3-.9 1.2-1.8 2.4-3.2 2.4-1.3 0-1.8-.8-3.3-.8s-2 .8-3.3.8c-1.4 0-2.4-1.3-3.3-2.5C2 18.4 1 14.4 2.8 11.5c.9-1.5 2.4-2.4 4-2.4 1.3 0 2.4.9 3.3.9.8 0 2.2-1 3.7-.9.6 0 2.4.3 3.5 1.9-3.1 2-2.6 6.3.2 7.5z"/></svg>
        <div style="text-align:left;"><small>{t(lang, 'hero.download_label')}</small><strong>App Store</strong></div>
      </a>
      <a href="#download" class="store-btn btn-hover" style="background:var(--color-brand-surface); border:1px solid var(--color-brand-line); color:var(--color-brand-t1);">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none"><path d="M3.5 2.5v19l11-9.5z" fill="#14F195"/><path d="M3.5 2.5l11 9.5 3.5-3z" fill="#4AA8FF"/><path d="M3.5 21.5l11-9.5 3.5 3z" fill="#FF9A4D"/><path d="M14.5 12l6-3.4 0 6.8z" fill="#B98CFF"/></svg>
        <div style="text-align:left;"><small>{t(lang, 'hero.download_label')}</small><strong>Google Play</strong></div>
      </a>
    </div>
    <div class="stats">
      <div><div class="num">{t(lang, 'hero.stats.exercises_value')}</div><div class="lbl">{t(lang, 'hero.stats.exercises_label')}</div></div>
      <div class="sep"></div>
      <div><div class="num">{t(lang, 'hero.stats.accuracy_value')}</div><div class="lbl">{t(lang, 'hero.stats.accuracy_label')}</div></div>
      <div class="sep"></div>
      <div><div class="num">{t(lang, 'hero.stats.rating_value')}<span style="color:var(--color-brand-gold); font-size:18px;"> ★</span></div><div class="lbl">{t(lang, 'hero.stats.rating_label')}</div></div>
    </div>
  </div>
  <div style="position:relative; z-index:2; display:flex; justify-content:center;">
    <div style="position:absolute; width:340px; height:340px; background:radial-gradient(circle, rgba(20,241,149,.2), transparent 62%); animation:gaiwGlow 4s ease-in-out infinite;"></div>
    <div style="position:relative; animation:gaiwFloat 6s ease-in-out infinite;">
      <div class="phone-shell"><div class="screen"><Image src={homeShot} alt={t(lang, 'showcase.slides.0.title')} width={290} densities={[1, 2, 3]} /></div></div>
    </div>
  </div>
</header>
