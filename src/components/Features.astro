---
import { t, type Lang } from '../i18n/utils';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
---
<section id="features" class="wrap">
  <div class="sec-head">
    <div class="sec-kicker">{t(lang, 'features.kicker')}</div>
    <h2>{t(lang, 'features.heading')}</h2>
  </div>
  <div class="feat-grid">
    <div class="card big">
      <div class="cglow"></div>
      <div class="ic" style="background:rgba(20,241,149,.13); border:1px solid rgba(20,241,149,.3); color:var(--color-brand-green);">
        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
      </div>
      <h3>{t(lang, 'features.camera.title')}</h3>
      <p>{t(lang, 'features.camera.desc')}</p>
      <div class="tagrow">
        <span class="tag" style="color:var(--color-brand-green); background:rgba(20,241,149,.1); border:1px solid rgba(20,241,149,.3);">{t(lang, 'features.camera.tag_1')}</span>
        <span class="tag" style="color:var(--color-brand-purple); background:rgba(185,140,255,.1); border:1px solid rgba(185,140,255,.3);">{t(lang, 'features.camera.tag_2')}</span>
        <span class="tag" style="color:var(--color-brand-blue); background:rgba(74,168,255,.1); border:1px solid rgba(74,168,255,.3);">{t(lang, 'features.camera.tag_3')}</span>
      </div>
    </div>
    <div class="card">
      <div class="ic" style="background:rgba(74,168,255,.12); border:1px solid rgba(74,168,255,.3); color:var(--color-brand-blue);">
        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="3"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
      </div>
      <h3>{t(lang, 'features.plans.title')}</h3>
      <p>{t(lang, 'features.plans.desc')}</p>
    </div>
    <div class="card">
      <div class="ic" style="background:rgba(245,197,67,.12); border:1px solid rgba(245,197,67,.3); color:var(--color-brand-gold);">
        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9a6 6 0 0 0 12 0V4H6zM6 4H3v2a3 3 0 0 0 3 3M18 4h3v2a3 3 0 0 1-3 3M9 21h6M12 15v6"/></svg>
      </div>
      <h3>{t(lang, 'features.community.title')}</h3>
      <p>{t(lang, 'features.community.desc')}</p>
    </div>
    <div class="card">
      <div class="ic" style="background:rgba(255,154,77,.12); border:1px solid rgba(255,154,77,.3); color:var(--color-brand-orange);">
        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="M7 15l4-5 3 3 5-7"/></svg>
      </div>
      <h3>{t(lang, 'features.progress.title')}</h3>
      <p>{t(lang, 'features.progress.desc')}</p>
    </div>
    <div class="card">
      <div class="ic" style="background:rgba(20,241,149,.12); border:1px solid rgba(20,241,149,.3); color:var(--color-brand-green);">
        <svg width="26" height="26" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l1.8 4.2L18 8l-4.2 1.8L12 14l-1.8-4.2L6 8l4.2-1.8z"/><circle cx="18.5" cy="16.5" r="2"/><circle cx="6" cy="17" r="1.4"/></svg>
      </div>
      <h3>{t(lang, 'features.chat.title')}</h3>
      <p>{t(lang, 'features.chat.desc')}</p>
    </div>
  </div>
</section>
